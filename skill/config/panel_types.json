[
  {
    "type": "text",
    "name": "富文本面板",
    "description": "展示富文本/Markdown 内容，支持三层阅读模式",
    "requiredFields": ["summary", "content", "format"],
    "optionalFields": ["wordCount", "toc"],
    "dataExample": {
      "summary": "摘要文本",
      "content": "# 标题\n正文内容...",
      "format": "markdown"
    }
  },
  {
    "type": "table",
    "name": "表格面板",
    "description": "展示结构化行列数据",
    "requiredFields": ["columns", "rows"],
    "optionalFields": ["footer"],
    "dataExample": {
      "columns": [{ "key": "name", "label": "名称" }, { "key": "value", "label": "数值", "align": "right", "format": "number" }],
      "rows": [{ "name": "项目A", "value": 100 }]
    }
  },
  {
    "type": "list",
    "name": "列表面板",
    "description": "展示带图标/标记的条目列表。注意：顶层字段是 items，不是 list",
    "requiredFields": ["items"],
    "optionalFields": ["emptyText"],
    "dataExample": {
      "items": [{ "id": "1", "title": "条目标题", "subtitle": "副标题", "icon": "star", "badge": { "text": "标签", "color": "green" } }]
    }
  },
  {
    "type": "chart",
    "name": "图表面板",
    "description": "展示数据可视化图表 (line/bar/pie/area)",
    "requiredFields": ["chartType", "data", "xAxis", "yAxis"],
    "optionalFields": ["legend", "colors"],
    "dataExample": {
      "chartType": "line",
      "data": [{ "label": "1月", "value": 100, "series": "销量" }],
      "xAxis": "月份",
      "yAxis": "销量"
    }
  },
  {
    "type": "code",
    "name": "代码面板",
    "description": "展示语法高亮代码块",
    "requiredFields": ["language", "code"],
    "optionalFields": ["highlightLines", "copyable", "filename"],
    "dataExample": {
      "language": "python",
      "code": "print('hello')",
      "filename": "main.py"
    }
  },
  {
    "type": "image",
    "name": "图片面板",
    "description": "展示图片 (base64/本地路径/URL)",
    "requiredFields": ["src"],
    "optionalFields": ["caption", "alt", "width", "height"],
    "dataExample": {
      "src": "https://example.com/img.png",
      "caption": "图片说明"
    }
  },
  {
    "type": "timeline",
    "name": "时间轴面板",
    "description": "展示时间轴事件 (day/week/month)。注意：顶层字段是 events，不是 timeline",
    "requiredFields": ["events", "viewMode"],
    "optionalFields": ["focusDate"],
    "dataExample": {
      "events": [{ "id": "1", "date": "2026-03-14", "title": "事件标题", "description": "详情", "color": "#3b82f6" }],
      "viewMode": "month"
    }
  },
  {
    "type": "kv",
    "name": "键值对面板",
    "description": "展示键值对/摘要卡片。注意：顶层字段是 items，不是 kv",
    "requiredFields": ["items"],
    "optionalFields": ["columns"],
    "dataExample": {
      "items": [{ "key": "价格", "value": "$99.00", "type": "number" }, { "key": "状态", "value": "正常", "type": "status", "status": "success" }],
      "columns": 2
    }
  },
  {
    "type": "html",
    "name": "自定义 HTML 面板",
    "description": "在 iframe 沙箱中渲染自定义 HTML，用于游戏、自定义可视化等。使用 html 字段传入内容（非 data），必须完全内联所有 JS/CSS",
    "requiredFields": [],
    "optionalFields": []
  }
]
